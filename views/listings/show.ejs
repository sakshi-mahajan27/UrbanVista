<% layout("/layouts/boilerplate") %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing  = <%- JSON.stringify(listing) %>;
</script>

<!-- ── Breadcrumb ── -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb" style="font-size:0.85rem;">
    <li class="breadcrumb-item"><a href="/listings" style="color:var(--primary);">Listings</a></li>
    <li class="breadcrumb-item active text-muted" aria-current="page"><%= listing.title %></li>
  </ol>
</nav>

<!-- ── Listing Header ── -->
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
    <div>
      <h1 class="display-6 fw-bold mb-1" style="color:var(--text-h);letter-spacing:-0.02em;"><%= listing.title %></h1>
      <p class="mb-0" style="color:var(--text-muted);font-size:0.95rem;">
        <i class="fa-solid fa-location-dot me-1" style="color:var(--primary);" aria-hidden="true"></i>
        <%= listing.location %>, <%= listing.country %>
      </p>
    </div>
    <div class="text-center px-4 py-3 rounded-3" style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;box-shadow:0 6px 20px rgba(254,66,77,.35);min-width:130px;flex-shrink:0;">
      <div style="font-size:1.6rem;font-weight:800;line-height:1;letter-spacing:-0.015em;">₹<%= listing.price.toLocaleString("en-IN") %></div>
      <small style="opacity:.85;font-size:0.78rem;font-weight:500;">/night</small>
    </div>
  </div>
</div>

<!-- ── Main content row ── -->
<div class="row g-4 mb-5">

  <!-- Left column -->
  <div class="col-12 col-lg-8">

    <!-- Hero image -->
    <div class="card show-card mb-4">
      <img
        src="<%= listing.image.url %>"
        class="show-img"
        alt="<%= listing.title %>"
      >
    </div>

    <!-- Details -->
    <div class="card mb-4" style="border-radius:var(--radius-xl);">
      <div class="card-body p-4">
        <div class="row g-4">

          <!-- Host -->
          <div class="col-12 col-sm-6">
            <p class="mb-1" style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-subtle);">Hosted by</p>
            <div class="d-flex align-items-center gap-2">
              <div class="d-flex align-items-center justify-content-center rounded-circle" style="width:38px;height:38px;background:var(--primary-light);flex-shrink:0;">
                <i class="fa-solid fa-user" style="font-size:1rem;color:var(--primary);" aria-hidden="true"></i>
              </div>
              <strong style="font-size:1.05rem;color:var(--text-h);"><%= listing.owner.username %></strong>
            </div>
          </div>

          <!-- Category -->
          <div class="col-12 col-sm-6">
            <p class="mb-1" style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-subtle);">Category</p>
            <span
              class="badge"
              style="background:var(--primary-light);color:var(--primary);font-size:0.85rem;padding:.45em .9em !important;border-radius:2rem;"
            ><%= listing.category %></span>
          </div>

          <!-- Description -->
          <div class="col-12">
            <p class="mb-2" style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-subtle);">About This Place</p>
            <p style="color:var(--text-body);line-height:1.75;margin:0;"><%= listing.description %></p>
          </div>

        </div>
      </div>
    </div>

    <!-- Map -->
    <div class="card mb-4 overflow-hidden" style="border-radius:var(--radius-xl);">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fa-solid fa-map-location-dot me-2" style="color:var(--primary);" aria-hidden="true"></i>Where You'll Be
        </h5>
      </div>
      <div class="card-body p-0">
        <div id="map" class="map"></div>
      </div>
    </div>

    <!-- Owner actions -->
    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
    <div class="card border-0 mb-4" style="background:linear-gradient(135deg,#fffbeb,#fff8f0);border:1.5px solid #fde68a !important;border-radius:var(--radius-xl);">
      <div class="card-body p-4">
        <p class="mb-3" style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#92400e;">
          <i class="fa-solid fa-screwdriver-wrench me-2" aria-hidden="true"></i>Manage Your Listing
        </p>
        <div class="d-flex flex-wrap gap-2">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-light">
            <i class="fa-solid fa-pen-to-square me-1" aria-hidden="true"></i>Edit Listing
          </a>
          <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" class="d-inline">
            <button
              type="submit"
              class="btn btn-danger"
              onclick="return confirm('Are you sure you want to delete this listing?');"
            >
              <i class="fa-solid fa-trash me-1" aria-hidden="true"></i>Delete Listing
            </button>
          </form>
        </div>
      </div>
    </div>
    <% } %>

  </div><!-- /col left -->

  <!-- Right column (reviews) -->
  <div class="col-12 col-lg-4">

    <!-- Review form -->
    <% if(currUser) { %>
    <div class="card mb-4" style="border-radius:var(--radius-xl);">
      <div class="card-header bg-primary">
        <h5 class="mb-0 text-white">
          <i class="fa-solid fa-star me-2" aria-hidden="true"></i>Leave a Review
        </h5>
      </div>
      <div class="card-body p-4">
        <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">

          <div class="mb-3">
            <label for="rating" class="form-label">Your Rating</label>
            <fieldset class="starability-slot" aria-label="Rating">
              <input type="radio" id="no-rate"    class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-4">
            <label for="comment" class="form-label">Your Comment</label>
            <textarea
              class="form-control"
              id="comment"
              name="review[comment]"
              rows="4"
              placeholder="Share your experience…"
              required
            ></textarea>
            <div class="invalid-feedback">Please add a comment.</div>
          </div>

          <button type="submit" class="btn btn-primary w-100">
            <i class="fa-solid fa-paper-plane me-1" aria-hidden="true"></i>Submit Review
          </button>
        </form>
      </div>
    </div>
    <% } else { %>
    <div class="alert alert-info mb-4" role="alert" style="border-radius:var(--radius-xl);">
      <i class="fa-solid fa-circle-info me-2" aria-hidden="true"></i>
      <a href="/login" style="color:var(--info);font-weight:600;">Log in</a> to leave a review.
    </div>
    <% } %>

    <!-- Reviews list -->
    <div class="card" style="border-radius:var(--radius-xl);">
      <div class="card-header">
        <h5 class="mb-0">
          <i class="fa-solid fa-comments me-2" style="color:var(--primary);" aria-hidden="true"></i>
          Reviews (<%= listing.reviews.length %>)
        </h5>
      </div>
      <div class="card-body p-3">
        <% if(listing.reviews.length === 0) { %>
          <div class="text-center py-4">
            <i class="fa-regular fa-star-half-stroke mb-2 d-block" style="font-size:2rem;color:var(--text-subtle);" aria-hidden="true"></i>
            <p class="mb-0" style="color:var(--text-muted);font-size:0.9rem;">No reviews yet.<br>Be the first to review!</p>
          </div>
        <% } else { %>
          <div class="d-flex flex-column gap-3">
            <% for(let review of listing.reviews) { %>
              <div class="p-3 rounded-3" style="background:var(--surface-2);border:1px solid var(--border);">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                  <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                      <div class="d-flex align-items-center justify-content-center rounded-circle" style="width:30px;height:30px;background:var(--primary-light);flex-shrink:0;">
                        <i class="fa-solid fa-user" style="font-size:0.75rem;color:var(--primary);" aria-hidden="true"></i>
                      </div>
                      <strong style="font-size:0.9rem;color:var(--text-h);"><%= review.author.username %></strong>
                    </div>
                    <p class="starability-result mb-0" data-rating="<%= review.rating %>"></p>
                  </div>
                  <% if(currUser && currUser._id.equals(review.author._id)) { %>
                    <form
                      method="POST"
                      action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                      class="d-inline"
                      onsubmit="return confirm('Delete this review?');"
                    >
                      <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Delete review">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
                <p style="font-size:0.875rem;color:var(--text-body);margin:0.5rem 0 0;line-height:1.6;"><%= review.comment %></p>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>

  </div><!-- /col right -->

</div><!-- /.row -->

<script src="/js/map.js"></script>
