<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center mb-5">
  <div class="col-12 col-md-9 col-lg-7 col-xl-6">

    <!-- Page header -->
    <div class="mb-4">
      <h1 class="h2 fw-800 mb-1" style="color:var(--text-h);letter-spacing:-0.025em;">
        <i class="fa-solid fa-pen me-2" style="color:var(--primary);" aria-hidden="true"></i>Edit Your Listing
      </h1>
      <p class="mb-0" style="color:var(--text-muted);font-size:0.9rem;">Update information for <strong><%= listing.title %></strong></p>
    </div>

    <!-- Form card -->
    <div class="card shadow-sm" style="border-radius:var(--radius-xl);">
      <div class="card-body p-4 p-sm-5">
        <form
          method="POST"
          action="/listings/<%= listing._id %>?_method=PUT"
          class="needs-validation"
          enctype="multipart/form-data"
          novalidate
        >

          <!-- Title -->
          <div class="mb-4">
            <label for="title" class="form-label">
              <i class="fa-solid fa-heading me-1" style="color:var(--primary);" aria-hidden="true"></i>Title
            </label>
            <input
              id="title"
              name="listing[title]"
              value="<%= listing.title %>"
              type="text"
              class="form-control form-control-lg"
              required
            />
            <div class="invalid-feedback">Please provide a catchy title.</div>
          </div>

          <!-- Description -->
          <div class="mb-4">
            <label for="description" class="form-label">
              <i class="fa-solid fa-align-left me-1" style="color:var(--primary);" aria-hidden="true"></i>Description
            </label>
            <textarea
              id="description"
              name="listing[description]"
              class="form-control"
              rows="5"
              required
            ><%= listing.description %></textarea>
            <div class="invalid-feedback">Please provide a short description.</div>
          </div>

          <!-- Current image preview -->
          <div class="mb-4">
            <label class="form-label">
              <i class="fa-solid fa-image me-1" style="color:var(--primary);" aria-hidden="true"></i>Current Image
            </label>
            <div class="rounded-3 overflow-hidden" style="max-height:240px;">
              <img
                src="<%= imageUrl %>"
                alt="Current listing image"
                class="img-fluid w-100"
                style="object-fit:cover;height:240px;display:block;"
              >
            </div>
          </div>

          <!-- Upload new image -->
          <div class="mb-4">
            <label for="image" class="form-label">
              <i class="fa-solid fa-upload me-1" style="color:var(--primary);" aria-hidden="true"></i>Upload New Image
              <span class="badge ms-1" style="background:var(--surface-3);color:var(--text-muted);font-weight:500;font-size:0.72rem;border-radius:2rem;padding:.25em .6em;">Optional</span>
            </label>
            <input
              id="image"
              name="listing[image]"
              type="file"
              class="form-control form-control-lg"
              accept="image/*"
            />
            <small class="text-muted d-block mt-1" style="font-size:0.8rem;">
              Leave empty to keep the current image &middot; JPG, PNG, GIF &middot; Max 5 MB
            </small>
          </div>

          <!-- Price & Country -->
          <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6">
              <label for="price" class="form-label">
                <i class="fa-solid fa-indian-rupee-sign me-1" style="color:var(--primary);" aria-hidden="true"></i>Price per Night
              </label>
              <div class="input-group">
                <span class="input-group-text" style="background:var(--surface-2);border-color:var(--border);color:var(--text-muted);">₹</span>
                <input
                  id="price"
                  name="listing[price]"
                  value="<%= listing.price %>"
                  type="number"
                  class="form-control form-control-lg"
                  min="0"
                  step="1"
                  required
                />
                <div class="invalid-feedback">Please provide a valid price.</div>
              </div>
            </div>
            <div class="col-12 col-sm-6">
              <label for="country" class="form-label">
                <i class="fa-solid fa-globe me-1" style="color:var(--primary);" aria-hidden="true"></i>Country
              </label>
              <input
                id="country"
                name="listing[country]"
                value="<%= listing.country %>"
                type="text"
                class="form-control form-control-lg"
                required
              />
              <div class="invalid-feedback">Please provide a valid country.</div>
            </div>
          </div>

          <!-- Location -->
          <div class="mb-4">
            <label for="location" class="form-label">
              <i class="fa-solid fa-location-dot me-1" style="color:var(--primary);" aria-hidden="true"></i>Location
            </label>
            <input
              id="location"
              name="listing[location]"
              value="<%= listing.location %>"
              type="text"
              class="form-control form-control-lg"
              required
            />
            <div class="invalid-feedback">Please provide a valid location.</div>
          </div>

          <!-- Category -->
          <div class="mb-5">
            <label for="category" class="form-label">
              <i class="fa-solid fa-tag me-1" style="color:var(--primary);" aria-hidden="true"></i>Category
            </label>
            <select id="category" name="listing[category]" class="form-select form-select-lg" required>
              <% const categories = ["City", "Beach", "Mountains", "Castles", "Pools", "Snow", "Camping", "Farms", "Lake", "Treehouse"]; %>
              <% for(let cat of categories) { %>
                <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>>
                  <% if(cat === 'City')       { %>🏙️ Iconic Cities
                  <% } else if(cat === 'Beach')     { %>🏖️ Beach Front
                  <% } else if(cat === 'Mountains') { %>⛰️ Mountains
                  <% } else if(cat === 'Castles')   { %>🏰 Castles
                  <% } else if(cat === 'Pools')     { %>🏊 Pools
                  <% } else if(cat === 'Snow')      { %>❄️ Snow Retreats
                  <% } else if(cat === 'Camping')   { %>⛺ Camping
                  <% } else if(cat === 'Farms')     { %>🚜 Farms
                  <% } else if(cat === 'Lake')      { %>🏞️ Lake View
                  <% } else if(cat === 'Treehouse') { %>🌳 Treehouse
                  <% } %>
                </option>
              <% } %>
            </select>
            <div class="invalid-feedback">Please select a category.</div>
          </div>

          <!-- Actions -->
          <div class="d-flex flex-column flex-sm-row gap-2">
            <button type="submit" class="btn btn-primary btn-lg flex-sm-fill">
              <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>Save Changes
            </button>
            <a href="/listings/<%= listing._id %>" class="btn btn-outline-danger btn-lg">
              <i class="fa-solid fa-xmark me-1" aria-hidden="true"></i>Cancel
            </a>
          </div>

        </form>
      </div>
    </div>

  </div>
</div>
